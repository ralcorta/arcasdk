{
  "name": "pdf",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/pdf/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/lib"
      ],
      "options": {
        "commands": [
          "npx tsc --project tsconfig.build.json",
          "tsc-alias -p tsconfig.build.json",
          "rsync -a --include='*/' --include='*.hbs' --exclude='*' src/ lib/"
        ],
        "parallel": false,
        "cwd": "packages/pdf"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "packages/pdf/jest.config.js",
        "passWithNoTests": false
      }
    },
    "test:unit": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "packages/pdf/jest.config.js",
        "passWithNoTests": false
      }
    },
    "test:coverage": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "packages/pdf/jest.config.js",
        "coverage": true,
        "passWithNoTests": false
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ]
    },
    "publish": {
      "executor": "@nx/js:release-publish",
      "options": {
        "packageRoot": "packages/pdf",
        "registry": "https://registry.npmjs.org/"
      },
      "dependsOn": [
        "build"
      ]
    },
    "version": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm version ${args.versionType} --no-git-tag-version",
        "cwd": "packages/pdf"
      }
    },
    "version:patch": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm version patch --no-git-tag-version",
        "cwd": "packages/pdf"
      }
    },
    "version:minor": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm version minor --no-git-tag-version",
        "cwd": "packages/pdf"
      }
    },
    "version:major": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm version major --no-git-tag-version",
        "cwd": "packages/pdf"
      }
    }
  },
  "tags": [
    "scope:pdf",
    "type:lib"
  ]
}