{
    "name": "core",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "packages/core/src",
    "projectType": "library",
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "outputs": [
                "{projectRoot}/lib"
            ],
            "options": {
                "commands": [
                    "npx tsc"
                ],
                "parallel": false,
                "cwd": "packages/core"
            },
            "dependsOn": [
                {
                    "target": "build",
                    "projects": "dependencies"
                }
            ]
        },
        "test": {
            "executor": "@nx/jest:jest",
            "outputs": [
                "{workspaceRoot}/coverage/{projectRoot}"
            ],
            "options": {
                "jestConfig": "packages/core/jest.config.js",
                "passWithNoTests": false
            },
            "configurations": {
                "unit": {
                    "jestConfig": "packages/core/jest.config.js"
                },
                "integration": {
                    "jestConfig": "packages/core/jest.integration.config.js",
                    "passWithNoTests": true
                }
            }
        },
        "test:unit": {
            "executor": "@nx/jest:jest",
            "outputs": [
                "{workspaceRoot}/coverage/{projectRoot}"
            ],
            "options": {
                "jestConfig": "packages/core/jest.config.js",
                "passWithNoTests": false
            }
        },
        "test:integration": {
            "executor": "@nx/jest:jest",
            "outputs": [
                "{workspaceRoot}/coverage/{projectRoot}"
            ],
            "options": {
                "jestConfig": "packages/core/jest.integration.config.js",
                "passWithNoTests": true
            }
        },
        "test:coverage": {
            "executor": "@nx/jest:jest",
            "outputs": [
                "{workspaceRoot}/coverage/{projectRoot}"
            ],
            "options": {
                "jestConfig": "packages/core/jest.config.js",
                "coverage": true,
                "passWithNoTests": false
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint",
            "outputs": [
                "{options.outputFile}"
            ]
        },
        "publish": {
            "executor": "@nx/js:release-publish",
            "options": {
                "packageRoot": "packages/core",
                "registry": "https://registry.npmjs.org/"
            },
            "dependsOn": [
                "build"
            ]
        },
        "version": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npm version ${args.versionType} --no-git-tag-version",
                "cwd": "packages/core"
            }
        },
        "version:patch": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npm version patch --no-git-tag-version",
                "cwd": "packages/core"
            }
        },
        "version:minor": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npm version minor --no-git-tag-version",
                "cwd": "packages/core"
            }
        },
        "version:major": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npm version major --no-git-tag-version",
                "cwd": "packages/core"
            }
        }
    },
    "tags": [
        "scope:core",
        "type:lib"
    ]
}
