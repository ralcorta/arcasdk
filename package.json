{
  "name": "arcasdk",
  "version": "0.1.0",
  "description": "Arca TypeScript SDK Monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "nx run-many --target=build --all",
    "build:core": "nx build core",
    "test": "nx run-many --target=test --all --skip-nx-cache",
    "test:coverage": "nx run-many --target=test --all --skip-nx-cache",
    "test:integration": "nx run-many --target=test:integration --all --skip-nx-cache",
    "test:integration:all": "npm run test:integration && npm run test:consumer:integration",
    "lint": "nx run-many --target=lint --all",
    "test:core": "nx test core",
    "test:core:unit": "nx test:unit core",
    "test:core:integration": "nx test:integration core",
    "pack:core": "node ./packages/core/tests/integration/scripts/pack-package-for-consumer.js packages/core --out packages/core/tests/integration/consumer-app/vendor/core.tgz",
    "install:consumer": "npm install ./packages/core/tests/integration/consumer-app/vendor/core.tgz --prefix packages/core/tests/integration/consumer-app",
    "test:consumer": "npm run pack:core && npm run install:consumer && env ENABLE_INTEGRATION_TESTS=false npm test --prefix packages/core/tests/integration/consumer-app",
    "test:consumer:integration": "npm run pack:core && npm run install:consumer && env ENABLE_INTEGRATION_TESTS=true npm run test:integration --prefix packages/core/tests/integration/consumer-app",
    "lint:core": "nx lint core",
    "publish:core": "nx publish core",
    "version:core": "nx version core --versionType=${VERSION:-patch}",
    "version:core:patch": "nx version:patch core",
    "version:core:minor": "nx version:minor core",
    "version:core:major": "nx version:major core",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "nx": "nx"
  },
  "author": "valiuLab",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nx/eslint": "^22.1.3",
    "@nx/jest": "^22.1.3",
    "@nx/js": "^22.1.3",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "mermaid": "^11.12.1",
    "nx": "^22.1.3",
    "tsconfig-paths": "^4.2.0",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ralcorta/arcasdk.git"
  },
  "bugs": {
    "url": "https://github.com/ralcorta/arcasdk/issues"
  },
  "homepage": "https://github.com/ralcorta/arcasdk#readme",
  "keywords": [
    "monorepo",
    "web-service",
    "factura-electronica",
    "padron",
    "arca",
    "afip",
    "sdk",
    "typescript",
    "soap",
    "wsaa"
  ]
}