# Test/Homologation Certificates Configuration
# Path to folder containing homologation certificates
# Can be absolute or relative to project root
TEST_CREDENTIALS_FOLDER=test-credentials

# Name of the private key file (homologation certificate)
TEST_PRIVATE_KEY_FILE_NAME=homologacion.key

# Name of the certificate file (homologation certificate)
TEST_CERT_FILE_NAME=homologacion.crt

# CUIT for testing (homologation environment)
# This is the CUIT associated with your homologation certificates
TEST_CUIT=20111111112

# Alternative: Use CUIT instead of TEST_CUIT
# CUIT=20111111112

# Node environment
NODE_ENV=test

# Integration tests (optional): only run with jest.integration.config.js
# (e.g. npm run test:core:integration or nx run core:test:integration).
# Requires real homologation certificate files at the paths configured above.
# ENABLE_INTEGRATION_TESTS=true
